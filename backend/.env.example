# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=yassine123
MINIO_BUCKET=ecom-media
MEDIA_PUBLIC_BASE_URL=https://localhost:8443/ecom-media

# Gateway HTTPS (manual local run)
GATEWAY_SSL_ENABLED=true
GATEWAY_SSL_KEY_STORE=../certs/gateway.p12
GATEWAY_SSL_KEY_STORE_PASSWORD=changeit
GATEWAY_SSL_KEY_STORE_TYPE=PKCS12

# JWT
JWT_PRIVATE_KEY_PATH=../keys/private.pem
JWT_PUBLIC_KEY_PATH=../keys/public.pem
JWT_EXPIRATION=86400000
